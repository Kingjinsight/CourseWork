@startuml Sponsor Performance

actor AdminStaff
participant GeneralController
participant AuthorisationService
participant AdminStaffController
participant EventRepository
participant BookingRepository
participant PaymentSystem
participant Performance

note over AdminStaff
The trigger bundles performanceID and amount
into one message to match the coursework's
single-threaded burst assumption.
end note

AdminStaff -> GeneralController: asAdminStaff()
activate AdminStaff
activate GeneralController
GeneralController -> AuthorisationService: requireRole(session, AdminStaff)

alt not logged in or wrong role
    activate AuthorisationService
    AuthorisationService --> GeneralController: error
    deactivate AuthorisationService
    GeneralController --> AdminStaff: error, not authorised
else authorised
    GeneralController --> AdminStaff: AdminStaffController
    deactivate GeneralController
end

AdminStaff -> AdminStaffController: sponsorPerformance(performanceID, amount)
activate AdminStaffController


AdminStaffController -> EventRepository: findPerformance(performanceID)
activate EventRepository
EventRepository --> AdminStaffController: performance
deactivate EventRepository

alt performance not found
    AdminStaffController --> AdminStaff: sponsorship failed (invalid performanceID)
else performance found
    AdminStaffController -> EventRepository: applySponsorship(performanceID, amount)
    activate EventRepository
    EventRepository -> Performance: canbeSponsored(amount)
    activate Performance
    Performance --> EventRepository: sponsorship eligibility
    deactivate Performance

    alt sponsorship rejected
        EventRepository --> AdminStaffController: rejected
        AdminStaffController --> AdminStaff: sponsorship failed (invalid sponsor amount)
    else sponsorship approved
        EventRepository --> AdminStaffController: approved
        deactivate EventRepository
        AdminStaffController -> Performance: applySponsorship(amount)
        activate Performance
        Performance --> AdminStaffController: void
        deactivate Performance
        AdminStaffController -> BookingRepository: findByPerformance(performanceID)
        activate BookingRepository
        BookingRepository --> AdminStaffController: bookings
        deactivate BookingRepository
        alt has bookings
            loop for each booking
                AdminStaffController -> PaymentSystem: processRefund(booking.amountPaid - Performance.ticketPrice, booking.contactEmail, messageToStudents)
                activate PaymentSystem
                PaymentSystem --> AdminStaffController: success / failure
                deactivate PaymentSystem
                alt PaymentSystem success
                    AdminStaffController-> booking: setAmountPaid(Performance.ticketPrice)
                    activate booking
                    booking --> AdminStaffController: void
                    deactivate booking
                else PaymentSystem failure
                    AdminStaffController --> AdminStaff: sponsorship failed (refund failed)
                end
            end
        end
    end   
end

AdminStaffController --> AdminStaff: sponsorship successful
deactivate AdminStaffController
deactivate AdminStaff

@enduml
