@startuml Cancel Performance

actor EntertainmentProvider
participant GeneralController
participant AuthorisationService
participant EntertainmentProviderController
participant EventRepository
participant BookingRepository
participant PaymentSystem
participant Performance

activate GeneralController

EntertainmentProvider -> GeneralController: asEP()
GeneralController -> AuthorisationService: requireRole(session, EntertainmentProvider)

alt not logged in or wrong role
    AuthorisationService --> GeneralController: error
    GeneralController --> EntertainmentProvider: error, not authorised
else authorised
    GeneralController --> EntertainmentProvider: EntertainmentProviderController
end

EntertainmentProvider -> EntertainmentProviderController: cancelPerformance(performanceID, messageToStudents)
activate EntertainmentProviderController

EntertainmentProviderController -> EventRepository: findPerformanceByEP(performanceID, epID)
EventRepository --> EntertainmentProviderController: performance

alt performance not found
    EntertainmentProviderController --> EntertainmentProvider: false (invalid performanceID or not owned)
else performance found
    EntertainmentProviderController -> BookingRepository: findByPerformance(performanceID)
    BookingRepository --> EntertainmentProviderController: bookings

    alt no bookings
        EntertainmentProviderController -> EventRepository: cancelPerformance(performanceID)
        EntertainmentProviderController --> EntertainmentProvider: true
    else has bookings
        loop for each booking
            EntertainmentProviderController -> PaymentSystem: processRefund(booking.amountPaid, booking.contactEmail, messageToStudents)
            PaymentSystem --> EntertainmentProviderController: success / failure
        end

        alt all refunds successful
            EntertainmentProviderController -> EventRepository: cancelPerformance(performanceID)
            EntertainmentProviderController --> EntertainmentProvider: true
        else any refund failed
            EntertainmentProviderController --> EntertainmentProvider: false (refund failed)
        end
    end
end

deactivate EntertainmentProviderController
deactivate GeneralController

@enduml
