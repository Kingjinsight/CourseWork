@startuml Cancel Performance

actor EntertainmentProvider
participant EventsAppView
participant GeneralController
participant AuthorisationService
participant EntertainmentProviderController
participant EventRepository
participant BookingRepository
participant PaymentSystem
participant Performance

activate EventsAppView

EntertainmentProvider -> EventsAppView: cancelPerformance(performanceID, messageToStudents)

EventsAppView -> GeneralController: asEP()
activate GeneralController
GeneralController -> AuthorisationService: requireRole(session, EntertainmentProvider)
activate AuthorisationService

alt not logged in or wrong role
    AuthorisationService --> GeneralController: error
    deactivate AuthorisationService
    GeneralController --> EventsAppView: error
    deactivate GeneralController
    EventsAppView --> EntertainmentProvider: error, not authorised
else authorised
    AuthorisationService --> GeneralController: ok
    deactivate AuthorisationService
    GeneralController --> EventsAppView: EntertainmentProviderController
    deactivate GeneralController
end

EventsAppView -> EntertainmentProviderController: cancelPerformance(performanceID, messageToStudents)
activate EntertainmentProviderController

EntertainmentProviderController -> EventRepository: findPerformanceByEP(performanceID, epID)
activate EventRepository
EventRepository --> EntertainmentProviderController: performance
deactivate EventRepository

alt performance not found
    EntertainmentProviderController --> EventsAppView: false (invalid performanceID or not owned)
    EventsAppView --> EntertainmentProvider: error, invalid performance
else performance found
    EntertainmentProviderController -> Performance: hasTakenPlace(currentTime)
    activate Performance
    Performance --> EntertainmentProviderController: result
    deactivate Performance

    alt performance has already taken place
        EntertainmentProviderController --> EventsAppView: false (already taken place)
        EventsAppView --> EntertainmentProvider: error, already taken place
    else performance has not taken place
        EntertainmentProviderController -> BookingRepository: findByPerformance(performanceID)
        activate BookingRepository
        BookingRepository --> EntertainmentProviderController: bookings
        deactivate BookingRepository

        alt no bookings
            EntertainmentProviderController -> EventRepository: cancelPerformance(performanceID)
            activate EventRepository
            EventRepository --> EntertainmentProviderController: done
            deactivate EventRepository
            EntertainmentProviderController --> EventsAppView: true
            EventsAppView --> EntertainmentProvider: confirmation
        else has bookings
            alt messageToStudents is empty
                EntertainmentProviderController --> EventsAppView: false (message required)
                EventsAppView --> EntertainmentProvider: error, message required
            else message is valid
                loop for each booking
                    EntertainmentProviderController -> PaymentSystem: processRefund(booking.amountPaid, booking.contactEmail, messageToStudents)
                    activate PaymentSystem
                    PaymentSystem --> EntertainmentProviderController: success / failure
                    deactivate PaymentSystem
                end

                alt all refunds successful
                    loop for each booking
                        EntertainmentProviderController -> BookingRepository: removeBooking(booking.bookingNumber)
                        activate BookingRepository
                        BookingRepository --> EntertainmentProviderController: done
                        deactivate BookingRepository
                    end

                    EntertainmentProviderController -> EventRepository: cancelPerformance(performanceID)
                    activate EventRepository
                    EventRepository --> EntertainmentProviderController: done
                    deactivate EventRepository
                    EntertainmentProviderController --> EventsAppView: true
                    EventsAppView --> EntertainmentProvider: confirmation + refunds processed
                else any refund failed
                    EntertainmentProviderController --> EventsAppView: false (refund failed)
                    EventsAppView --> EntertainmentProvider: error, cannot cancel
                end
            end
        end
    end
end

deactivate EntertainmentProviderController
deactivate EventsAppView

@enduml
