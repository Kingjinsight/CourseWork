@startuml Task 2

/'central controller
currentUser used to distinguish user type, student or adminstaff or ep by access users
'/
class EventsApp {
    - currentUser: AuthenticatingUser 
    - users: Collection<AuthenticatingUser>
    - events: Collection<Event>
    + login(email: String, Password: String): void
    + logout(): void
    + registerEntertainmentProvider()
    + createEvent()
    + searchPerformances()
    + viewPerformance()
    + bookPerformance()
    + editPreferences()
    + cancelPerformance(performanceID: String, message: String): void
    + cancelBooking(bookingNumber: String): void
    + reviewPerformance(performanceID: String, rating: int, comment: String): Review
    + sponsorPerformance(performanceID: String, amount: String): Boolean

}

abstract class AuthenticatingUser {
    - userID: String
    - email: String
    - password: String
}

class EntertainmentProvider {
    - name: String
    - businessNumber: String
    - description: String
}

class AdminStaff {
}

class Student {
    - preferences: Collection<EventType>
}

class Performance {
    - performanceID: String
    - startDateTime: Date
    - endDateTime: Date 
    - performerNames: Collection<String>
    - ticketPrice: double
    - sponsorshipAmount: double
    - remainingTickets: int
    - venueAddress: String 
    - venueCapacity: int
    - isOutdoor: Boolean
    - isSmoking: Boolean
    + applySponsorship(amount: double): void
    + canBeSponsored(amount: double): Boolean
    + hasTakenPlace(currentTime: Date): Boolean
    + isSponsorable(): Boolean
    + validate(performanceID: String): Boolean
    + cancel(): void
}

class Booking {
    - bookingNumber: String
    - numTickets: int
    - studentName: String
    - contactEmail: String
    - contactPhone: String
    + getBookingsFor(performanceID: String): Collection<Booking>
}

class Review {
    - rating: int
    - comment: String
}

class Event {
    - eventID: String
    - title: String
    - type: EventType
    - isTicketed: Boolean
    + addReview(review: Review): void
    + calculateAverageRating(): double
}

interface VerificationSystem {
    + verifyBusiness(businessNumber: String): Boolean
}

interface PaymentSystem {
    + processPayment(amount: double, userID: String): Boolean
    + processRefund(bookings: Collection<Booking>, message: String): void
}

enum EventType {
   Music
   Theatre
   Dance
   Movie
   Sports
   Games
}


EventsApp "1" -- "0..*" AuthenticatingUser
EventsApp "1" -- "0..*" Event
EventsApp ..> PaymentSystem
EventsApp ..> VerificationSystem

AuthenticatingUser <|-- AdminStaff
AuthenticatingUser <|-- EntertainmentProvider
AuthenticatingUser <|-- Student

Student "1" -- "0..*" Review
Student "1" -- "0..*" Booking


Booking "0..*" -- "1" Performance
Review "0..*" -- "1" Performance
Performance "0..*" -- "1" Event
Event "0..*" -- "1" EntertainmentProvider
Event "1" -- "0..*" Review

note right of Review
Stored against the Event, while the linked
Performance preserves which attended
performance the review refers to.
end note

note right of Performance
sponsorshipAmount stores the discount
applied to future search, view and
booking flows.
end note
@enduml
