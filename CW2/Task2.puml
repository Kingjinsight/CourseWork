@startuml Task 2

skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50
left to right direction

' - One general controller (system entry point) that actors talk to
' - Role/identity decides which actor-specific subcontroller handles the request
' - Data is NOT stored in the controller; repositories hold data
' - External systems shown as interfaces (per requirements)

'========================
' Session + Authorisation
'========================
class Session {
  - currentUser: AuthenticatingUser
  + isLoggedIn(): Boolean
  + login(user: AuthenticatingUser): void
  + logout(): void
  + getCurrentUser(): AuthenticatingUser
}

class AuthorisationService {
  + requireLoggedIn(session: Session): void
  + requireRole(session: Session, role: UserRole): void
}

enum UserRole {
  Student
  AdminStaff
  EntertainmentProvider
}

'========================
' General controller + actor-based subcontrollers
'========================
class GeneralController {
  - session: Session
  - auth: AuthorisationService
  - users: UserRepository
  - events: EventRepository
  - bookings: BookingRepository
  - reviews: ReviewRepository
  - studentCtrl: StudentController
  - epCtrl: EntertainmentProviderController
  - adminCtrl: AdminStaffController

  + login(email: String, password: String): Boolean
  + logout(): void
  + searchPerformances(date: Date): Collection<Performance>
  + viewPerformance(performanceID: String): Performance

  + asStudent(): StudentController
  + asEP(): EntertainmentProviderController
  + asAdminStaff(): AdminStaffController
}

abstract class AbstractSubController {
  # session: Session
  # auth: AuthorisationService
  # users: UserRepository
  # events: EventRepository
  # bookings: BookingRepository
  # reviews: ReviewRepository
}

class StudentController {
  + bookPerformance(performanceID: String, numTickets: int, contactEmail: String, contactPhone: String): Booking
  + cancelBooking(bookingNumber: String): Boolean
  + editPreferences(preferences: Collection<EventType>): void
  + reviewPerformance(performanceID: String, rating: int, comment: String): Review
}

class EntertainmentProviderController {
  + registerEntertainmentProvider(name: String, businessNumber: String, description: String, email: String, password: String): Boolean
  + createEvent(e: Event): void
  + createPerformance(eventID: String, p: Performance): void
  + cancelPerformance(performanceID: String, messageToStudents: String): Boolean
}

class AdminStaffController {
  + sponsorPerformance(performanceID: String, amount: double): Boolean
}

class EventsAppView {
  - controller: GeneralController
  + displayError(message: String): void
  + displayConfirmation(message: String): void
}

AbstractSubController <|-- StudentController
AbstractSubController <|-- EntertainmentProviderController
AbstractSubController <|-- AdminStaffController

GeneralController "1" o-- "1" Session
GeneralController "1" o-- "1" AuthorisationService
GeneralController "1" o-- "1" UserRepository
GeneralController "1" o-- "1" EventRepository
GeneralController "1" o-- "1" BookingRepository
GeneralController "1" o-- "1" ReviewRepository
GeneralController "1" o-- "1" StudentController
GeneralController "1" o-- "1" EntertainmentProviderController
GeneralController "1" o-- "1" AdminStaffController


EventsAppView ..> GeneralController
EventsAppView ..> StudentController
EventsAppView ..> EntertainmentProviderController
EventsAppView ..> AdminStaffController
'========================
' Repositories (data split)
'========================
class UserRepository {
  - users: Collection<AuthenticatingUser>
  + findByEmail(email: String): AuthenticatingUser
  + addUser(u: AuthenticatingUser): void
  + updateStudentPreferences(studentID: String, preferences: Collection<EventType>): void
}

class EventRepository {
  - events: Collection<Event>
  + addEvent(e: Event): void
  + findPerformance(performanceID: String): Performance
  + findPerformanceByEP(performanceID: String, epID: String): Performance
  + searchPerformances(date: Date): Collection<Performance>
  + cancelPerformance(performanceID: String): void
  + addPerformance(eventID: String, p: Performance): void
  + addReviewToEvent(eventID: String, review: Review): void
  + applySponsorship(performanceID: String, amount: double): Boolean
  + removeEvent(eventID:String): void
}

class BookingRepository {
  - bookings: Collection<Booking>
  + addBooking(b: Booking): void
  + findByBookingNumber(bookingNumber: String): Booking
  + findByPerformance(performanceID: String): Collection<Booking>
  + removeBooking(bookingNumber: String): void
}

class ReviewRepository {
  - reviews: Collection<Review>
  + addReview(r: Review): void
}

GeneralController ..> EventRepository : searchPerformances / viewPerformance
GeneralController ..> UserRepository : login
StudentController ..> UserRepository : editPreferences
StudentController ..> EventRepository
StudentController ..> BookingRepository
StudentController ..> ReviewRepository
StudentController ..> PaymentSystem

EntertainmentProviderController ..> UserRepository : registerEntertainmentProvider
EntertainmentProviderController ..> EventRepository
EntertainmentProviderController ..> PaymentSystem
EntertainmentProviderController ..> VerificationSystem
EntertainmentProviderController ..> BookingRepository

AdminStaffController ..> EventRepository


abstract class AuthenticatingUser {
  - userID: String
  - email: String
  - password: String
}

class EntertainmentProvider {
  - name: String
  - businessNumber: String
  - description: String
}

class AdminStaff {
}

class Student {
  - preferences: Collection<EventType>
}

class Performance {
  - performanceID: String
  - eventID: String
  - startDateTime: Date
  - endDateTime: Date
  - performerNames: Collection<String>
  - ticketPrice: double
  - sponsorshipAmount: double
  - remainingTickets: int
  - venueAddress: String
  - venueCapacity: int
  - isOutdoor: Boolean
  - isSmoking: Boolean

  + applySponsorship(amount: double): void
  + canBeSponsored(amount: double): Boolean
  + hasTakenPlace(currentTime: Date): Boolean
  + isSponsorable(): Boolean
  + cancel(): void
}

class Booking {
  - bookingNumber: String
  - performanceID: String
  - userID: String
  - numTickets: int
  - studentName: String
  - contactEmail: String
  - contactPhone: String
  - amountPaid: double
}

class Review {
  - performanceID: String
  - userID: String
  - rating: int
  - comment: String
}

class Event {
  - eventID: String
  - title: String
  - type: EventType
  - isTicketed: Boolean
  - entertainmentProvider: EntertainmentProvider
  + addReview(review: Review): void
  + calculateAverageRating(): double
}

enum EventType {
  Music
  Theatre
  Dance
  Movie
  Sports
  Games
}

' User inheritance
AuthenticatingUser <|-- AdminStaff
AuthenticatingUser <|-- EntertainmentProvider
AuthenticatingUser <|-- Student

' Key associations + multiplicities
Event "0..*" -- "1" EntertainmentProvider
Performance "0..*" -- "1" Event
Booking "0..*" -- "1" Performance
Review "0..*" -- "1" Performance
Event "1" -- "0..*" Review
Student "1" -- "0..*" Booking
Student "1" -- "0..*" Review

note right of Review
Stored against the Event, while the linked
Performance preserves which attended
performance the review refers to.
end note

note right of Performance
No separate Venue entity (requirement).
Venue info is stored as attributes.
end note


'========================
' External systems
'========================
interface VerificationSystem {
  + verifyBusiness(businessNumber: String): Boolean
}

interface PaymentSystem {
  + processPayment(amount: double, userID: String): Boolean
  + processRefund(amount: double, studentEmail: String, message: String): Boolean
}

@enduml
